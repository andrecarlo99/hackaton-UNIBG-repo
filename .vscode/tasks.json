{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Auto Setup: UV Sync",
            "type": "shell",
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "uv sync --active --all-extras"
                ]
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
