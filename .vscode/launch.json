{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open venv terminal",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-lc",
                    "if [ -f .venv/bin/activate ]; then source .venv/bin/activate; fi; exec bash -l"
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": []
        }
    ]
}
